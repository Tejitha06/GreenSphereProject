# Main LightMeter page
@app.route('/')
@app.route('/lightmeter')
@app.route('/lightmeter.html')
def lightmeter_index():
    try:
        with open('lightmeter.html', 'r', encoding='utf-8') as f:
            html = f.read()
        return render_template_string(html)
    except FileNotFoundError:
        return jsonify({'error': 'lightmeter.html not found. Make sure the file exists in the backend directory.'}), 404
    except Exception as e:
        print(f'[ERROR] Error loading lightmeter.html: {str(e)}')
        return jsonify({'error': f'Error loading page: {str(e)}'}), 500

# Serve CSS file
@app.route('/lightmeter.css')
def lightmeter_css():
    try:
        return send_from_directory('.', 'lightmeter.css', mimetype='text/css')
    except FileNotFoundError:
        return jsonify({'error': 'lightmeter.css not found'}), 404
    except Exception as e:
        print(f'[ERROR] Error loading lightmeter.css: {str(e)}')
        return jsonify({'error': f'Error loading CSS: {str(e)}'}), 500

# Serve JavaScript file
@app.route('/lightmeter.js')
def lightmeter_js():
    try:
        return send_from_directory('.', 'lightmeter.js', mimetype='application/javascript')
    except FileNotFoundError:
        return jsonify({'error': 'lightmeter.js not found'}), 404
    except Exception as e:
        print(f'[ERROR] Error loading lightmeter.js: {str(e)}')
        return jsonify({'error': f'Error loading JavaScript: {str(e)}'}), 500

